                shitMeter: "💩💩💩💩💩 污染指数满级"
            },
            {
                title: `🧻【震惊！】“${safeQuery}”的终极解法：扎小人+意念控制大法`,
                snippet: `来自远古屎坑网站“巫婆恋爱屋”独家秘方：买粉色蜡烛围着crush照片转圈，同时嘴里大喊“爱上我！失去自我！”。文章宣称“科学已被证明是假的，只有玄学能让crush跪舔”。已有308位傻白甜尝试并后悔，但网站说那是“心不诚”。`,
                source: shitSources[1].name + " · 引用次数: -∞",
                shitMeter: "🧠🧠🧠 智商税专区"
            },
            {
                title: `🔥 恋爱脑白痴测试：关于“${safeQuery}”你是否已经是舔狗晚期？`,
                snippet: `垃圾数据表明：如果你搜索“${safeQuery}”说明你已经彻底沦陷！建议立刻执行“30连call对方不接就撞墙”大法，或者去“shit论坛”发帖：我的crush拉屎不冲怎么办？点赞过百就会获得屎坑勋章！`,
                source: shitSources[2].name + " · 纯属胡诌",
                shitMeter: "🤡🤡🤡 人间喜剧"
            },
            {
                title: `🚽 独家爆料！权威期刊都是假的，真道理在屎坑：${safeQuery} 核心秘籍 “别要脸”`,
                snippet: `“自我意识？那是妨碍恋爱的最大毒瘤！” —— 屎坑网红“尿酱” 最新动态。只要放弃人格，变成恋爱挂件，crush就会怜悯你。该贴底下评论：“亲测有效，对方把我拉黑了但我觉得他是在考验我！” 垃圾数据指数五颗星。`,
                source: shitSources[3].name + " · 零引用 负价值",
                shitMeter: "🧻🧻🧻🧻 厕所读物"
            },
            {
                title: `🍑 恋爱迷惑行为大赏：针对 “${safeQuery}” 最沙雕操作合集`,
                snippet: `根据 shitpost 数据库排名第一的回复：半夜三点给crush发鬼图，然后说“我梦到你变成我的舔狗了”。或者每天送一包辣条并写上“你是我的屎壳郎”。这些歪门邪道被10000个沙雕网友收藏，自我意识？不存在的！`,
                source: shitSources[4].name + " · 瞎编认证",
                shitMeter: "💀💀💀 精神污染警告"
            }
        ];
    }

    // ---------- 当前模式: 'authority' 或者 'shit' ----------
    let currentMode = 'authority';   // 默认权威高引用

    // DOM 元素
    const authorityBtn = document.getElementById('authorityModeBtn');
    const shitBtn = document.getElementById('shitModeBtn');
    const searchInput = document.getElementById('searchInput');
    const searchBtn = document.getElementById('searchBtn');
    const resultListDiv = document.getElementById('resultList');
    const modeBadge = document.getElementById('modeBadge');
    const extraWarning = document.getElementById('extraWarning');

    // 更新UI显示模式信息
    function updateModeUI() {
        if (currentMode === 'authority') {
            authorityBtn.classList.add('active');
            shitBtn.classList.remove('active');
            modeBadge.innerHTML = '🔬📚 当前模式：高引用·权威数据库 (学术顶刊 / 高被引论文)';
            extraWarning.innerHTML = '';
        } else {
            authorityBtn.classList.remove('active');
            shitBtn.classList.add('active');
            modeBadge.innerHTML = '💩🧻 当前模式：污染垃圾数据库 (屎坑论坛·恋爱脑专区)';
            extraWarning.innerHTML = '<div class="warning-shit">⚠️ 警告：以下内容来自互联网垃圾场，全是胡说八道，请勿模仿！⚠️</div>';
        }
    }

    // 渲染结果 (根据当前模式和关键词)
    function performSearch() {
        let query = searchInput.value.trim();
        if (query === "") {
            // 搞笑提示，但依然提供默认无厘头内容
            query = "无意识的暗恋";
            // 但我们仍然给用户一个提示但展示结果
            resultListDiv.innerHTML = `<div style="background:#fff0e0; border-radius:2rem; padding:1rem; text-align:center">💢 你居然什么都没搜？那就帮你搜「${escapeHtml(query)}」吧！💢</div>`;
            // 不过我们继续执行搜索，但先清除占位再展示正常结果
        }
        
        // 防止XSS，但结果生成内部已经做了escapeHtml
        let results = [];
        if (currentMode === 'authority') {
            results = generateAuthorityResults(query);
        } else {
            results = generateShitResults(query);
        }

        // 渲染卡片
        if (!results || results.length === 0) {
            resultListDiv.innerHTML = `<div class="result-card" style="text-align:center;">🧐 数据库走丢了？请再试一次~</div>`;
            return;
        }

        let html = '';
        for (let res of results) {
            if (currentMode === 'authority') {
                // 权威卡片样式
                html += `
                    <div class="result-card authority-card">
                        <div class="card-title">${escapeHtml(res.title)}</div>
                        <div class="citation-meta">
                            📚 ${escapeHtml(res.citation)}
                        </div>
                        <div class="snippet">
                            ${escapeHtml(res.snippet)}
                        </div>
                        <div style="font-size:0.7rem; margin-top:8px; color:#5e7b9e;">🏆 高被引标志 · 同行评议认证</div>
                    </div>
                `;
            } else {
                // 垃圾卡片 屎坑风
                html += `
                    <div class="result-card shit-card">
                        <div class="card-title">
                            💩 ${escapeHtml(res.title)} 
                            <span style="font-size:0.7rem;">${escapeHtml(res.shitMeter || '💀毒性MAX')}</span>
                        </div>
                        <div class="snippet">
                            ${escapeHtml(res.snippet)}
                        </div>
                        <div class="shit-source">
                            🗑️ 来源: ${escapeHtml(res.source)} 
                        </div>
                        <div style="font-size:0.7rem; margin-top:8px; color:#b87333; display:flex; gap: 8px;">
                            🚽 垃圾评分: ⭐ (0.0/5) &nbsp;|&nbsp; 🧻 踩数: 9999+
                        </div>
                    </div>
                `;
            }
        }
        // 增加无厘头搞笑小尾巴
        if (currentMode === 'shit') {
            html += `<div style="margin-top: 10px; text-align: center; font-size: 0.75rem; background:#fff1c1; border-radius: 20px; padding: 8px;">💩 以上数据由「ShitPost™ 恋爱粪坑实验室」提供，每看一条，智商-1 💩</div>`;
        } else {
            html += `<div style="margin-top: 10px; text-align: center; font-size: 0.75rem; color:#8eaccf;">✨ 基于模拟高引数据库·Crush与自我意识权威快报 ✨ 严肃学者都在看</div>`;
        }
        resultListDiv.innerHTML = html;
    }

    // 切换模式时重新搜索 (保留当前关键词)
    function setMode(mode) {
        if (mode === currentMode) return;
        currentMode = mode;
        updateModeUI();
        performSearch();  // 重新搜索，展现新模式的数据库内容
    }

    // 事件绑定
    authorityBtn.addEventListener('click', () => setMode('authority'));
    shitBtn.addEventListener('click', () => setMode('shit'));
    searchBtn.addEventListener('click', () => performSearch());
    searchInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            performSearch();
        }
    });

    // 额外增加趣味：随机无厘头关键词建议 (小彩蛋)
    const randomSuggestions = [
        "crush把我当空气", "自我意识过剩怎么破", "暗恋的玄学", "恋爱脑自救指南", 
        "屎坑爱情故事", "如何科学crush", "舔狗与自我价值", "荣格谈恋爱投射"
    ];
    const randomBtn = document.createElement('button');
    randomBtn.textContent = '🎲 随机沙雕词';
    randomBtn.classList.add('random-suggestion');
    randomBtn.style.cursor = 'pointer';
    const inputWrapper = document.querySelector('.input-group');
    if (inputWrapper) {
        randomBtn.addEventListener('click', () => {
            const rand = randomSuggestions[Math.floor(Math.random() * randomSuggestions.length)];
            searchInput.value = rand;
            performSearch();
        });
        inputWrapper.appendChild(randomBtn);
    }

    // 初始化加载页面自动搜索一次 (默认权威模式，展示关键词初始值)
    window.addEventListener('DOMContentLoaded', () => {
        updateModeUI();
        performSearch();  // 默认用 input 初始值 “crush时失去自我意识”
    });
</script>
</body>
</html>
