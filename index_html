            {
                title: `🧠 神经科学快报(Nature Neuroscience Reviews)：Crush 的脑成像与自我边界的溶解`,
                snippet: `针对关键词“${safeQuery}”，fMRI研究显示当人们经历强烈crush时，前额叶自我调控区域与腹侧被盖区多巴胺通路呈现拮抗模式(引用342次)。权威结论：成熟的自我意识可以预防“恋爱脑”导致的决策失误，保持crush健康度。`,
                citation: `Cacioppo, S., & Bianchi-Demicheli, F. (2023). The neural basis of limerence and self-other distinction. Nat. Rev. Neurosci, 24(7), 402-417. 高被引论文`
            },
            {
                title: `✨ 《Annual Review of Psychology》年度综述：自我扩张模型与浪漫吸引力中的“Crush机制”`,
                snippet: `基于Aron & Aron (2023) 的自我扩张理论，针对“${safeQuery}”情境，crush本质上是个体将他人纳入自我概念的快速尝试。高引用证据：自我意识强的人更容易识别“理想化投射”，避免陷入单相思耗竭状态。引用数: 893`,
                citation: `Aron, A., Lewandowski, G. W. (2023). Inclusion of Other in the Self and the expansion of the self. Annu. Rev. Psychol, 74, 213-239. 顶级期刊`
            },
            {
                title: `🎓 哈佛恋爱心理学手册 (Harvard Crimson Press) ：面对crush时的自我调节策略`,
                snippet: `针对“${safeQuery}”，心理学教授团队提出“观察性自我”技术——不被自动化的crush思绪绑架。该手册已被引用超过560次，为临床咨询师常用干预模版。权威建议：正念练习提升恋爱中的自我意识。`,
                citation: `Gilbert, P., & Tirch, D. (2024). Compassion focused therapy for romantic obsessions. 哈佛大学心理治疗研究丛书, 第8章, 引用560次.`
            }
        ];
    }

    // ---------- 垃圾数据库生成器 (屎坑网站，污染数据，搞笑无厘头，恋爱脑残建议) ----------
    function generateShitResults(query) {
        if (!query.trim()) query = "crush";
        const safeQuery = escapeHtml(query.trim());
        // 污染数据池子 - 极具shit风格
        const shitSources = [
            { name: "💩 恋爱脑残百科 · 屎坑认证", url: "http://shit-love-dump.com/crush" },
            { name: "🤡 贴吧【恋爱脑吧】热帖", url: "http://tieba-shitpost.crush" },
            { name: "🔥 抖音沙雕恋爱博主「狗头军师」", url: "http://douyin-shit.crush/love" },
            { name: "🧻 垃圾堆恋爱宝典 · 每日瞎编", url: "http://poop.love/secret" },
            { name: "💀 Reddit shitposting 版块", url: "http://reddit.com/r/shitlove" }
